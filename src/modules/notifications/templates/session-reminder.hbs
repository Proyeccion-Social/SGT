836 51.1028C21.9764 55.2048 24.6346 58.9166 27.9943 62.1133C32.3389 66.2471 37.3903 69.1158 43.1761 70.6929C45.1711 71.2366 45.3085 71.6082 44.1586 73.3094C40.4243 78.8325 35.2382 81.7477 28.5632 81.8522C24.1857 81.9205 19.8046 81.7903 15.4282 81.8818C8.70104 82.0224 5.10747 74.9859 7.72676 69.6556C9.56605 65.912 11.7385 62.3318 13.7785 58.6876C15.2393 56.0776 16.726 53.4822 18.2543 50.7934Z" fill="url(#srem_lg2)"/><defs><linearGradient id="srem_lg0" x1="49.03" y1="3.22" x2="49.03" y2="88.34" gradientUnits="userSpaceOnUse"><stop offset="0.5" stop-color="#CFB9FF"/><stop offset="1" stop-color="#8751FF"/></linearGradient><linearGradient id="srem_lg1" x1="49.03" y1="3.22" x2="49.03" y2="88.34" gradientUnits="userSpaceOnUse"><stop stop-color="#CFB9FF"/><stop offset="1" stop-color="#9F74FF"/></linearGradient><linearGradient id="srem_lg2" x1="25.88" y1="50.11" x2="25.88" y2="81.88" gradientUnits="userSpaceOnUse"><stop stop-color="#CFB9FF"/><stop offset="1" stop-color="#8751FF"/></linearGradient></defs></svg>
                  </td>
                </tr>
              </table>
              <p style="margin:10px 0 0;font-size:11px;font-weight:600;color:#a3a3a3;letter-spacing:0.08em;text-transform:uppercase;">Atlas · Gestión de Tutorías</p>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:36px 40px;">
              {{#if is24Hours}}
              <h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#1a1a1a;">Tienes una sesión mañana</h1>
              {{else}}
              <h1 style="margin:0 0 8px;font-size:22px;font-weight:700;color:#1a1a1a;">Tu sesión comienza en 2 horas</h1>
              {{/if}}

              <!-- Countdown badge -->
              <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 0 20px;">
                <tr>
                  {{#if is24Hours}}
                  <td style="background-color:#e7dcff;border-radius:20px;padding:6px 16px;font-size:13px;font-weight:700;color:#513199;border:1px solid #cfb9ff;">En 24 horas</td>
                  {{else}}
                  <td style="background-color:#fcf4db;border-radius:20px;padding:6px 16px;font-size:13px;font-weight:700;color:#91792e;border:1px solid #f2c94c;">En 2 horas</td>
                  {{/if}}
                </tr>
              </table>

              <p style="margin:0 0 6px;font-size:15px;color:#3c3c3c;line-height:1.6;">Hola, <strong>{{recipientName}}</strong>.</p>
              <p style="margin:0 0 24px;font-size:15px;color:#3c3c3c;line-height:1.6;">
                {{#if (eq recipientRole 'tutor')}}
                  Recuerda que tienes una sesión de tutoria con <strong>{{counterpartName}}</strong> en <strong>{{timeUntilSession}}</strong>.
                {{else}}
                  Recuerda que tienes una sesión de tutoria con el tutor <strong>{{counterpartName}}</strong> en <strong>{{timeUntilSession}}</strong>.
                {{/if}}
              </p>

              <!-- Detail table -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 20px;border-top:1px solid #c6c6c6;">
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;width:45%;border-bottom:1px solid #c6c6c6;">Materia</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{subjectName}}</td>
                </tr>
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;border-bottom:1px solid #c6c6c6;">Tema</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{title}}</td>
                </tr>
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;border-bottom:1px solid #c6c6c6;">Fecha</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{date}}</td>
                </tr>
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;border-bottom:1px solid #c6c6c6;">Horario</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{startTime}} &#8211; {{endTime}}</td>
                </tr>
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;border-bottom:1px solid #c6c6c6;">Modalidad</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{modality}}</td>
                </tr>
                {{#if location}}
                <tr>
                  <td style="padding:11px 0;font-size:13px;color:#a3a3a3;font-weight:600;border-bottom:1px solid #c6c6c6;">Ubicación</td>
                  <td style="padding:11px 0;font-size:13px;color:#1a1a1a;text-align:right;border-bottom:1px solid #c6c6c6;">{{location}}</td>
                </tr>
                {{/if}}
              </table>

              {{#if virtualLink}}
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;background-color:#f3edff;border-radius:8px;">
                <tr>
                  <td style="padding:13px 16px;font-size:13px;color:#513199;border-left:3px solid #8751ff;">
                    Enlace de acceso: <a href="{{virtualLink}}" style="color:#8751ff;font-weight:700;word-break:break-all;">{{virtualLink}}</a>
                  </td>
                </tr>
              </table>
              {{/if}}

              <!-- Buttons -->
              <table role="presentation" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background-color:#8751ff;border-radius:8px;">
                    <a href="{{sessionDetailsUrl}}" style="display:inline-block;padding:13px 24px;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;">Ver detalles</a>
                  </td>
                  {{#if is24Hours}}
                  <td style="width:12px;"></td>
                  <td style="border-radius:8px;border:1px solid #c6c6c6;">
                    <a href="{{cancelUrl}}" style="display:inline-block;padding:12px 24px;font-size:14px;font-weight:600;color:#3c3c3c;text-decoration:none;">Cancelar sesión</a>
                  </td>
                  {{/if}}
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:20px 40px;border-top:1px solid #c6c6c6;text-align:center;">
              <p style="margin:0;font-size:12px;color:#a3a3a3;line-height:1.6;">
                Atlas · Universidad Distrital Francisco José de Caldas<br/>
                Este mensaje fue generado automaticamente, por favor no respondas a este correo.
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
