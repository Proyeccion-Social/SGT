<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recordatorio de sesión</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f4f4f5; font-family: Arial, sans-serif; }
    .wrapper { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header-24 { background-color: #0369a1; padding: 32px 40px; }
    .header-2  { background-color: #b45309; padding: 32px 40px; }
    .header-24 h1, .header-2 h1 { margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; }
    .header-24 p { margin: 6px 0 0; color: #bae6fd; font-size: 14px; }
    .header-2  p { margin: 6px 0 0; color: #fde68a; font-size: 14px; }
    .countdown { text-align: center; padding: 20px; }
    .countdown-badge { display: inline-block; padding: 10px 24px; border-radius: 24px; font-size: 18px; font-weight: 700; }
    .badge-24 { background: #dbeafe; color: #1e40af; }
    .badge-2  { background: #fef3c7; color: #92400e; }
    .body { padding: 24px 40px 32px; }
    .body p { color: #374151; font-size: 15px; line-height: 1.6; margin: 0 0 16px; }
    .detail-box { background: #f9fafb; border-left: 4px solid #9ca3af; border-radius: 4px; padding: 16px 20px; margin: 20px 0; }
    .detail-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid #e5e7eb; font-size: 14px; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: #6b7280; font-weight: 600; }
    .detail-value { color: #111827; text-align: right; }
    .virtual-box { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 12px 16px; font-size: 14px; color: #1d4ed8; margin: 12px 0; }
    .virtual-box a { color: #1d4ed8; font-weight: 700; word-break: break-all; }
    .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }
    .btn { display: inline-block; padding: 12px 24px; border-radius: 6px; font-size: 14px; font-weight: 700; text-decoration: none; }
    .btn-primary   { background-color: #1d4ed8; color: #ffffff; }
    .btn-secondary { background-color: #ffffff; color: #6b7280; border: 1px solid #d1d5db; }
    .footer { background: #f9fafb; padding: 20px 40px; text-align: center; font-size: 12px; color: #9ca3af; border-top: 1px solid #e5e7eb; }
  </style>
</head>
<body>
  <div class="wrapper">
    {{#if is24Hours}}
    <div class="header-24">
      <h1>Tienes una sesión mañana</h1>
      <p>Atlas — Sistema de Gestión de Tutorías</p>
    </div>
    {{else}}
    <div class="header-2">
      <h1>Tu sesión comienza en 2 horas</h1>
      <p>Atlas — Sistema de Gestión de Tutorías</p>
    </div>
    {{/if}}

    <div class="countdown">
      {{#if is24Hours}}
      <span class="countdown-badge badge-24">⏰ En 24 horas</span>
      {{else}}
      <span class="countdown-badge badge-2">⚡ En 2 horas</span>
      {{/if}}
    </div>

    <div class="body">
      <p>Hola, <strong>{{recipientName}}</strong>.</p>
      <p>
        {{#if (eq recipientRole 'tutor')}}
          Recuerda que tienes una sesión de tutoría con <strong>{{counterpartName}}</strong> en <strong>{{timeUntilSession}}</strong>.
        {{else}}
          Recuerda que tienes una sesión de tutoría con el tutor <strong>{{counterpartName}}</strong> en <strong>{{timeUntilSession}}</strong>.
        {{/if}}
      </p>

      <div class="detail-box">
        <div class="detail-row">
          <span class="detail-label">Materia</span>
          <span class="detail-value">{{subjectName}}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Tema</span>
          <span class="detail-value">{{title}}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Fecha</span>
          <span class="detail-value">{{date}}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Horario</span>
          <span class="detail-value">{{startTime}} – {{endTime}}</span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Modalidad</span>
          <span class="detail-value">{{modality}}</span>
        </div>
        {{#if location}}
        <div class="detail-row">
          <span class="detail-label">Ubicación</span>
          <span class="detail-value">{{location}}</span>
        </div>
        {{/if}}
      </div>

      {{#if virtualLink}}
      <div class="virtual-box">
        🔗 Enlace de acceso: <a href="{{virtualLink}}">{{virtualLink}}</a>
      </div>
      {{/if}}

      
    </div>
    <div class="footer">
      Atlas · Universidad Distrital Francisco José de Caldas<br/>
      Este mensaje fue generado automáticamente, por favor no respondas a este correo.
    </div>
  </div>
</body>
</html>
